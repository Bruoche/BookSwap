meta {
  name: Login (User)
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "testuser",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200) {
    const body = res.getBody();
    bru.setEnvVar("token", body.token);
  }
}
