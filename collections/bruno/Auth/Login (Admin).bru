meta {
  name: Login (Admin)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "otman",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200) {
    const body = res.getBody();
    bru.setEnvVar("adminToken", body.token);
  }
}
