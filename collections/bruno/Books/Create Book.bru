meta {
  name: Create Book
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/books
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "isbn": "9781234567890",
    "title": "My New Book",
    "description": "A great book about great things.",
    "publicationYear": 2024,
    "coverUrl": null,
    "authors": [1],
    "genres": [1]
  }
}
